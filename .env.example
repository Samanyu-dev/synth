# Synth MVP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Data Paths (CSV files) ===
TRIATHLON_DAILY_CSV=data/Copy of Triathlon Training Sync-daily_summary.csv
TRIATHLON_ACTIVITIES_CSV=data/Copy of Triathlon Training Sync-activities_raw.csv
ROWING_DATA_DIR=data

# === Optional ===
DB_PATH=synth.db
LOG_LEVEL=INFO
RATE_LIMIT=10/minute
