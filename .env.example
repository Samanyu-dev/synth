# Synth MVP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Data Paths ===
TRIATHLON_DATA_PATH=data/Copy of Triathlon Training Sync.xlsx
ROWING_DATA_PATH=data/rowing_women_2025-2026 ERGS-2.xlsx

# === Optional ===
DB_PATH=synth.db
LOG_LEVEL=INFO
RATE_LIMIT=10/minute
